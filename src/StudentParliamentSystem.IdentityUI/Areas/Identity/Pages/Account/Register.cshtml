@page
@model RegisterModel
@{
    ViewData["Title"] = "Реєстрація";
}

<div class="flex justify-center items-start py-8">
    <div class="card bg-base-100 shadow-xl border border-base-200 w-full max-w-md">
        <div class="card-body gap-6">
            <div class="text-center">
                <h1 class="text-3xl font-bold">Реєстрація</h1>
                <p class="text-base-content/60 mt-1">Створіть новий акаунт</p>
            </div>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="flex flex-col gap-4">
                <div asp-validation-summary="ModelOnly" class="alert alert-error text-sm" role="alert"></div>

                <div class="flex flex-col sm:flex-row gap-4">
                    <div class="form-control w-full">
                        <label asp-for="Input.FirstName" class="label"><span class="label-text font-medium">Ім'я</span></label>
                        <input asp-for="Input.FirstName" class="input input-bordered w-full" autocomplete="given-name" aria-required="true" placeholder="Іван" />
                        <span asp-validation-for="Input.FirstName" class="label-text-alt text-error mt-1"></span>
                    </div>

                    <div class="form-control w-full">
                        <label asp-for="Input.LastName" class="label"><span class="label-text font-medium">Прізвище</span></label>
                        <input asp-for="Input.LastName" class="input input-bordered w-full" autocomplete="family-name" aria-required="true" placeholder="Шевченко" />
                        <span asp-validation-for="Input.LastName" class="label-text-alt text-error mt-1"></span>
                    </div>
                </div>

                <div class="form-control">
                    <label asp-for="Input.Email" class="label"><span class="label-text font-medium">Email</span></label>
                    <input asp-for="Input.Email" class="input input-bordered w-full" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="label-text-alt text-error mt-1"></span>
                </div>

                <div class="form-control">
                    <label asp-for="Input.Password" class="label"><span class="label-text font-medium">Пароль</span></label>
                    <input asp-for="Input.Password" class="input input-bordered w-full" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="label-text-alt text-error mt-1"></span>
                </div>

                <div class="form-control">
                    <label asp-for="Input.ConfirmPassword" class="label"><span class="label-text font-medium">Підтвердження паролю</span></label>
                    <input asp-for="Input.ConfirmPassword" class="input input-bordered w-full" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Input.ConfirmPassword" class="label-text-alt text-error mt-1"></span>
                </div>

                <button id="registerSubmit" type="submit" class="btn btn-primary w-full">Зареєструватись</button>

                <p class="text-center text-sm text-base-content/60">
                    Вже маєте акаунт? <a asp-page="./Login" class="link link-primary">Увійти</a>
                </p>
            </form>

            @{
                if ((Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <div class="divider">Або через</div>
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="flex flex-wrap gap-2">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" class="btn btn-outline flex-1" name="provider" value="@provider.Name"
                                    title="Log in using your @provider.DisplayName account">@provider.DisplayName</button>
                        }
                    </form>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
