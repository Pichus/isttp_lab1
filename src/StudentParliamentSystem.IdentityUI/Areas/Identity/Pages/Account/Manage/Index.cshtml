@page
@model IndexModel
@{
    ViewData["Title"] = "Профіль";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3 class="text-xl font-semibold mb-4">@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="card bg-base-100 border border-base-200 shadow-sm">
    <div class="card-body">
        <form id="profile-form" method="post" class="flex flex-col gap-4 max-w-md">
            <div asp-validation-summary="ModelOnly" class="alert alert-error text-sm" role="alert"></div>

            <div class="form-control">
                <label asp-for="Username" class="label"><span class="label-text font-medium">Ім'я користувача</span></label>
                <input asp-for="Username" class="input input-bordered w-full" placeholder="Ваше ім'я користувача" disabled />
            </div>

            <div class="form-control">
                <label asp-for="Input.PhoneNumber" class="label"><span class="label-text font-medium">Номер телефону</span></label>
                <input asp-for="Input.PhoneNumber" class="input input-bordered w-full" placeholder="+380XXXXXXXXX" />
                <span asp-validation-for="Input.PhoneNumber" class="label-text-alt text-error mt-1"></span>
            </div>

            <button id="update-profile-button" type="submit" class="btn btn-primary">Зберегти</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
