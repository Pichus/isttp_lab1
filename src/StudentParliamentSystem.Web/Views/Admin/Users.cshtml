@model StudentParliamentSystem.Core.Abstractions.PagedResult<StudentParliamentSystem.Core.Aggregates.User.UserPreview>

@{
    ViewData["Title"] = "Управління Користувачами";
}

<div class="mb-8 flex justify-between items-end flex-wrap gap-4">
    <div>
        <h1 class="text-4xl font-black mb-2 flex items-center gap-3">
            Користувачі
            <span class="badge badge-lg badge-neutral">3 всього</span>
        </h1>
        <p class="text-base-content/70">Управління доступом, ролями та користувачами системи.</p>
    </div>
    <div>
        <button class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Додати Користувача
        </button>
    </div>
</div>

<div class="bg-base-100 shadow-xl rounded-3xl border border-base-200 p-6 mb-8 flex flex-col sm:flex-row gap-4">
    <form method="get" asp-action="Users" class="form-control w-full">
        <label class="label"><span class="label-text font-bold">Пошук користувача</span></label>
        <div class="input-group flex w-full">
            <input type="text" name="query" value="@ViewBag.Query" placeholder="Ім'я, email, або ID" class="input input-bordered w-full rounded-r-none"/>
            <button type="submit" class="btn btn-square btn-neutral rounded-l-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
            </button>
        </div>
    </form>
</div>

<div class="overflow-x-auto bg-base-100 rounded-3xl shadow-xl border border-base-200">
    <table class="table table-zebra w-full">
        <!-- head -->
        <thead>
        <tr class="bg-base-200 text-sm">
            <th>Користувач</th>
            <th>Електронна пошта</th>
            <th>Ролі / Статуси</th>
            <th>Департамент</th>
            <th>Дії</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var user in Model.Items)
        {
            <tr class="hover">
                <td>
                    <div class="flex items-center space-x-3">
                        <div class="avatar placeholder">
                            <div class="bg-neutral text-neutral-content rounded-full w-10">
                                <span class="text-sm uppercase">@(user.FirstName.FirstOrDefault())@(user.LastName.FirstOrDefault())</span>
                            </div>
                        </div>
                        <div>
                            <div class="font-bold">@user.FirstName @user.LastName</div>
                        </div>
                    </div>
                </td>
                <td class="text-sm">@user.Email</td>
                <td>
                    <div class="flex flex-wrap gap-1">
                        @if (user.Roles != null && user.Roles.Any())
                        {
                            @foreach (var role in user.Roles)
                            {
                                <span class="badge badge-success badge-sm font-bold">@role</span>
                            }
                        }
                        else
                        {
                            <span class="text-base-content/50">—</span>
                        }
                    </div>
                </td>
                <td>
                    @if (user.Departments != null && user.Departments.Any())
                    {
                        <span class="font-semibold text-sm">@string.Join(", ", user.Departments)</span>
                    }
                    else
                    {
                        <span class="text-base-content/50">—</span>
                    }
                </td>
                <th>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-ghost btn-sm">Редагувати</a>
                </th>
            </tr>
        }
        </tbody>
    </table>
</div>

<!-- Pagination -->
<div class="flex flex-col items-center mt-8 mb-4 gap-4">
    <div class="join shadow-sm">
        @if (Model.CurrentPage > 1)
        {
            <a asp-action="Users" asp-route-page="@(Model.CurrentPage - 1)" asp-route-query="@ViewBag.Query"
               class="join-item btn bg-base-100 hover:bg-base-200 border-base-200">«</a>
        }
        else
        {
            <button class="join-item btn btn-disabled bg-base-100 border-base-200">«</button>
        }

        @{
            var pageNumbers = new List<int>();
            for (var i = 1; i <= Model.TotalPages; i++)
            {
                if (i == 1 || i == Model.TotalPages || (i >= Model.CurrentPage - 1 && i <= Model.CurrentPage + 1))
                {
                    pageNumbers.Add(i);
                }
            }

            int? lastPageNumber = null;
        }

        @foreach (var p in pageNumbers)
        {
            if (lastPageNumber != null && p - lastPageNumber > 1)
            {
                <button class="join-item btn btn-disabled bg-base-100 border-base-200 pointer-events-none">...</button>
            }

            if (p == Model.CurrentPage)
            {
                <button class="join-item btn btn-active btn-neutral pointer-events-none">@p</button>
            }
            else
            {
                <a asp-action="Users" asp-route-page="@p" asp-route-query="@ViewBag.Query"
                   class="join-item btn bg-base-100 hover:bg-base-200 border-base-200">@p</a>
            }

            lastPageNumber = p;
        }

        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a asp-action="Users" asp-route-page="@(Model.CurrentPage + 1)" asp-route-query="@ViewBag.Query"
               class="join-item btn bg-base-100 hover:bg-base-200 border-base-200">»</a>
        }
        else
        {
            <button class="join-item btn btn-disabled bg-base-100 border-base-200">»</button>
        }
    </div>
    <div class="text-sm text-base-content/70 font-medium">
        Сторінка @Model.CurrentPage з @Model.TotalPages
    </div>
</div>