@page
@model SetPasswordModel
@{
    ViewData["Title"] = "Встановлення паролю";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3 class="text-xl font-semibold mb-4">@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="alert alert-info mb-6 text-sm">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
    <span>У вас ще немає локального пароля. Додайте пароль, щоб мати змогу входити без зовнішнього акаунту.</span>
</div>

<div class="card bg-base-100 border border-base-200 shadow-sm">
    <div class="card-body">
        <form id="set-password-form" method="post" class="flex flex-col gap-4 max-w-md">
            <div asp-validation-summary="ModelOnly" class="alert alert-error text-sm" role="alert"></div>

            <div class="form-control">
                <label asp-for="Input.NewPassword" class="label"><span class="label-text font-medium">Новий пароль</span></label>
                <input asp-for="Input.NewPassword" class="input input-bordered w-full" autocomplete="new-password" placeholder="••••••••" />
                <span asp-validation-for="Input.NewPassword" class="label-text-alt text-error mt-1"></span>
            </div>

            <div class="form-control">
                <label asp-for="Input.ConfirmPassword" class="label"><span class="label-text font-medium">Підтвердження паролю</span></label>
                <input asp-for="Input.ConfirmPassword" class="input input-bordered w-full" autocomplete="new-password" placeholder="••••••••" />
                <span asp-validation-for="Input.ConfirmPassword" class="label-text-alt text-error mt-1"></span>
            </div>

            <button type="submit" class="btn btn-primary">Встановити пароль</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
