@{
    ViewData["Title"] = "Статистика та Аналітика";
}

<div class="mb-8 flex justify-between items-end flex-wrap gap-4">
    <div>
        <h1 class="text-4xl font-black mb-2">Статистика та Звіти</h1>
        <p class="text-base-content/70">Аналітика діяльності департаментів та генерація звітів для Деканату.</p>
    </div>
    <div class="flex gap-2">
        <button class="btn btn-accent btn-sm lg:btn-md flex items-center gap-1">
             <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m.75 12 3 3m0 0 3-3m-3 3v-6m-1.5-9H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
            Генерувати Звіт для Деканату
        </button>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="stat bg-base-100 shadow-xl rounded-2xl border border-base-200">
        <div class="stat-figure text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-8 h-8 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
        </div>
        <div class="stat-title">Активних Членів СПФ</div>
        <div class="stat-value text-primary">124</div>
        <div class="stat-desc">↗︎ 14 нових цього місяця</div>
    </div>
    
    <div class="stat bg-base-100 shadow-xl rounded-2xl border border-base-200">
        <div class="stat-figure text-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-8 h-8 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <div class="stat-title">Проведених Заходів</div>
        <div class="stat-value text-secondary">32</div>
        <div class="stat-desc">↗︎ На 15% більше ніж торік</div>
    </div>
    
    <div class="stat bg-base-100 shadow-xl rounded-2xl border border-base-200">
        <div class="stat-figure text-accent">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-8 h-8 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
        </div>
        <div class="stat-title">Годин Коворкінгу</div>
        <div class="stat-value text-accent">1,200</div>
        <div class="stat-desc">Загалом заброньовано</div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Chart Mock 1 -->
    <div class="bg-base-100 p-6 rounded-3xl shadow-xl border border-base-200">
        <h3 class="text-xl font-bold mb-4">Активність Департаментів</h3>
        <div class="h-64 bg-base-200 rounded-xl flex items-end justify-around p-4 items-center border border-dashed border-base-300">
            <!-- Mock Bar Chart -->
            <div class="flex flex-col items-center gap-2">
                <div class="w-12 bg-primary rounded-t-sm h-48 hover:opacity-80 transition-opacity cursor-pointer"></div>
                <div class="text-xs font-bold">КультДеп</div>
            </div>
            <div class="flex flex-col items-center gap-2">
                 <div class="w-12 bg-secondary rounded-t-sm h-32 hover:opacity-80 transition-opacity cursor-pointer"></div>
                <div class="text-xs font-bold">IT-Відділ</div>
            </div>
            <div class="flex flex-col items-center gap-2">
                 <div class="w-12 bg-accent rounded-t-sm h-40 hover:opacity-80 transition-opacity cursor-pointer"></div>
                <div class="text-xs font-bold">СпортДеп</div>
            </div>
             <div class="flex flex-col items-center gap-2">
                 <div class="w-12 bg-base-300 rounded-t-sm h-24 hover:opacity-80 transition-opacity cursor-pointer"></div>
                <div class="text-xs font-bold">HR</div>
            </div>
        </div>
    </div>

     <!-- Table Mock -->
    <div class="bg-base-100 p-6 rounded-3xl shadow-xl border border-base-200">
        <h3 class="text-xl font-bold mb-4">Топ Заходів за Учасниками</h3>
        <div class="overflow-x-auto">
          <table class="table table-sm w-full">
            <thead>
              <tr class="bg-base-200 text-base-content text-sm">
                <th>Назва</th>
                <th>Учасників</th>
                <th>Рейтинг</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="font-bold">Посвята Першокурсників '25</td>
                <td>420</td>
                <td class="text-warning">★ 4.9</td>
              </tr>
              <tr>
                <td class="font-bold">Кіберспортивний Турнір</td>
                <td>156</td>
                <td class="text-warning">★ 4.8</td>
              </tr>
              <tr>
                <td class="font-bold">Лекція IT-Резиденції</td>
                <td>110</td>
                <td class="text-warning">★ 4.9</td>
              </tr>
               <tr>
                <td class="font-bold">Осінній Акустичний Вечір</td>
                <td>95</td>
                <td class="text-warning">★ 4.7</td>
              </tr>
            </tbody>
          </table>
        </div>
    </div>
</div>
