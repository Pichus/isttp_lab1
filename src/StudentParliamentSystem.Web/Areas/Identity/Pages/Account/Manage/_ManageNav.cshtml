@using StudentParliamentSystem.Infrastructure.Identity.Data.Entities
@using StudentParliamentSystem.Infrastructure.Identity
@inject SignInManager<ApplicationUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}
<ul class="menu menu-vertical bg-base-100 rounded-box border border-base-200 p-2 gap-1 w-full">
    <li><a class="@ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="./Index">Профіль</a></li>
    <li><a class="@ManageNavPages.EmailNavClass(ViewContext)" id="email" asp-page="./Email">Email</a></li>
    <li><a class="@ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="./ChangePassword">Пароль</a>
    </li>
    @if (hasExternalLogins)
    {
        <li id="external-logins"><a id="external-login" class="@ManageNavPages.ExternalLoginsNavClass(ViewContext)"
                                    asp-page="./ExternalLogins">Зовнішні входи</a></li>
    }
    <li><a class="@ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)" id="two-factor"
           asp-page="./TwoFactorAuthentication">Двофакторна автентифікація</a></li>
    <li><a class="@ManageNavPages.PersonalDataNavClass(ViewContext)" id="personal-data" asp-page="./PersonalData">Персональні
            дані</a></li>
</ul>
