<!DOCTYPE html>
<html lang="uk" data-theme="light">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Студпарламент ФКНК</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true"/>
</head>
<body class="bg-base-200 min-h-screen text-base-content font-sans">

<!-- Navbar -->
<div class="navbar bg-base-100 shadow-xl mb-8">
    <div class="navbar-start">
        <div class="dropdown">
            <label tabindex="0" class="btn btn-ghost lg:hidden">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16"/>
                </svg>
            </label>
            <ul tabindex="0"
                class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52 gap-2">
                <li><a href="/Events">Заходи</a></li>
                <li><a href="/Coworking">Коворкінг</a></li>
                <li><a href="/Statistics">Статистика</a></li>
                <li><a href="/Admin">Адмін панель</a></li>
            </ul>
        </div>
        <a href="/"
           class="btn btn-ghost normal-case text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-primary to-secondary">Студпарламент
            ФКНК</a>
    </div>
    <div class="navbar-center hidden lg:flex">
        <ul class="menu menu-horizontal px-1 gap-2 font-medium">
            <li><a href="/Events" class="hover:text-primary transition-colors">Заходи</a></li>
            <li><a href="/Coworking" class="hover:text-primary transition-colors">Коворкінг</a></li>
            <li><a href="/Statistics" class="hover:text-primary transition-colors">Статистика</a></li>
            <li><a href="/Admin" class="hover:text-primary transition-colors">Адмін панель</a></li>
        </ul>
    </div>
    <div class="navbar-end gap-2">
        @* <a class="btn btn-ghost hover:bg-base-200">Увійти</a> *@
        <partial name="_LoginPartial"/>
    </div>
</div>

<!-- Main Content -->
<div class="container mx-auto px-4 pb-12 w-full max-w-7xl">
    <main role="main">
        @RenderBody()
    </main>
</div>

<!-- Footer -->
<footer class="footer items-center p-4 bg-base-300 text-base-content mt-auto">
    <aside class="items-center grid-flow-col">
        <p>Студпарламент ФКНК КНУ ім. Тараса Шевченка © @DateTime.Now.Year - Всі права захищено</p>
    </aside>
</footer>

@await RenderSectionAsync("Scripts", false)
</body>
</html>
