@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Перевірте пошту";
}

<div class="flex justify-center items-start py-12">
    <div class="card bg-base-100 shadow-xl border border-base-200 w-full max-w-md">
        <div class="card-body items-center text-center gap-4">
            <div class="w-16 h-16 rounded-full bg-success/10 flex items-center justify-center text-success">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                     stroke="currentColor" class="w-8 h-8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
                </svg>
            </div>
            <h1 class="text-2xl font-bold">@ViewData["Title"]</h1>
            <p class="text-base-content/70">Будь ласка, перевірте вашу пошту для скидання паролю.</p>
            <a asp-page="./Login" class="btn btn-primary mt-2">До входу</a>
        </div>
    </div>
</div>
