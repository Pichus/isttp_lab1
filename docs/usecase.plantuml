@startuml Student_Parliament_UseCases
title Use Case Diagram: Студентський Парламент ФКНК
left to right direction

actor "Гість" as Guest
actor "Член СПФ" as Member
actor "Член Читалкадепу" as Coworking
actor "Голова Читалкадепу" as CoworkingHead
actor "Голова Департаменту" as DeptHead
actor "Супер-Адмін" as Admin

Guest <|-- Member
Member <|-- Coworking
Coworking <|-- CoworkingHead
Member <|-- DeptHead
Member <|-- Admin

package "Система Студентського Парламенту" {
    (Перегляд заходів) as ViewEvents
    (Пошук та фільтрація) as Search
    (Перегляд статистики) as Stats
    (Перегляд деталей заходу) as ViewDetails
    (Реєстрація на захід) as Register
    (Скасування реєстрації) as CancelReg
    (Створення заходу) as CreateEvent
    (Редагування заходу) as EditEvent
    (Запит на бронювання читалки) as BookRequest
    (Перегляд розкладу коворкінгу) as ViewSlots
    (Підтвердження бронювання) as Approve
    (Відхилення бронювання) as Reject
    (Призначення адміністратора) as AssignManager
    (Генерація подання для деканату) as GenDoc
    (Перегляд департаменту) as ViewDept
    (Додавання учасника) as AddMember
    (Зміна голови департаменту) as ChangeHead
    (Управління користувачами) as ManageUsers
    (Управління департаментами) as ManageDepts
    (Seed тестових даних) as Seed
}

Guest --> ViewEvents
Guest --> Stats

Member --> ViewDetails
Member --> Register
Member --> CancelReg
Member --> CreateEvent
Member --> EditEvent
Member --> BookRequest
Member --> ViewSlots
Member --> ViewDept

Coworking --> Approve
Coworking --> Reject

CoworkingHead --> GenDoc

DeptHead --> AddMember
DeptHead --> ChangeHead

Admin --> ManageUsers
Admin --> ManageDepts
Admin --> Seed

ViewEvents <.. Search : <<extend>>
ViewEvents <.. ViewDetails : <<extend>>
Register ..> ViewDetails : <<include>>
Approve ..> AssignManager : <<include>>
GenDoc ..> ViewSlots : <<include>>
ManageDepts <.. ChangeHead : <<extend>>

@enduml