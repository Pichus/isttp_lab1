@{
    ViewData["Title"] = "Редагувати Захід";
}

<div class="max-w-3xl mx-auto">
    <div class="mb-8">
        <h1 class="text-4xl font-black mb-2">Редагування Заходу</h1>
        <p class="text-base-content/70">Змініть інформацію про захід "#1 Посвята".</p>
    </div>

    <!-- Form Container -->
    <div class="bg-base-100 shadow-xl rounded-3xl border border-base-200 p-8">
        <form action="/Events/Details/1" method="post" class="space-y-6">
            
            <div class="form-control w-full">
                <label class="label">
                    <span class="label-text font-bold text-base">Назва заходу <span class="text-error">*</span></span>
                </label>
                <input type="text" value="Посвята Першокурсників" class="input input-bordered input-lg w-full bg-base-200/50" required />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Date -->
                <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text font-bold text-base">Дата та час початку <span class="text-error">*</span></span>
                    </label>
                    <input type="datetime-local" class="input input-bordered w-full bg-base-200/50" value="2026-10-12T18:00" required />
                </div>
                
                <!-- Max Participants -->
                <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text font-bold text-base">Макс. учасників</span>
                    </label>
                    <input type="number" value="300" class="input input-bordered w-full bg-base-200/50" />
                </div>
            </div>

            <!-- Location -->
            <div class="form-control w-full">
                <label class="label">
                    <span class="label-text font-bold text-base">Локація</span>
                </label>
                <input type="text" value="Малий актовий зал" class="input input-bordered w-full bg-base-200/50" />
            </div>

            <div class="form-control w-full">
                <label class="label">
                    <span class="label-text font-bold text-base">Опис заходу <span class="text-error">*</span></span>
                </label>
                <textarea class="textarea textarea-bordered h-40 bg-base-200/50 text-base" required>Грандіозна подія для всіх студентів першого курсу. Не пропусти!</textarea>
            </div>

            <div class="divider"></div>

            <div class="flex flex-col-reverse sm:flex-row justify-between items-center gap-4">
                <a href="/Events/Details/1" class="btn btn-ghost rounded-full px-6">Скасувати</a>
                <div class="flex gap-2 w-full sm:w-auto">
                     <button type="button" class="btn btn-error btn-outline rounded-full w-full sm:w-auto">Видалити</button>
                    <button type="submit" class="btn btn-primary btn-lg rounded-full px-10 shadow-lg shadow-primary/30 w-full sm:w-auto">Зберегти Зміни</button>
                </div>
            </div>
        </form>
    </div>
</div>
