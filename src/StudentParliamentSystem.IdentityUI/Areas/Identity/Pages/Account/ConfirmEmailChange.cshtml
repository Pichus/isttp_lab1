@page
@model ConfirmEmailChangeModel
@{
    ViewData["Title"] = "Підтвердження зміни email";
}

<div class="flex justify-center items-start py-12">
    <div class="card bg-base-100 shadow-xl border border-base-200 w-full max-w-md">
        <div class="card-body items-center text-center gap-4">
            <div class="w-16 h-16 rounded-full bg-success/10 flex items-center justify-center text-success">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                     stroke="currentColor" class="w-8 h-8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                </svg>
            </div>
            <h1 class="text-2xl font-bold">@ViewData["Title"]</h1>
            <partial name="_StatusMessage" model="Model.StatusMessage"/>
            <a asp-page="./Manage/Email" class="btn btn-primary mt-2">Керування email</a>
        </div>
    </div>
</div>
