@page
@model ExternalLoginsModel
@{
    ViewData["Title"] = "Зовнішні входи";
    ViewData["ActivePage"] = ManageNavPages.ExternalLogins;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3 class="text-xl font-semibold mb-4">@ViewData["Title"]</h3>

@if (Model.CurrentLogins?.Count > 0)
{
    <div class="card bg-base-100 border border-base-200 shadow-sm mb-6">
        <div class="card-body">
            <h4 class="font-semibold mb-3">Підключені акаунти</h4>
            <div class="overflow-x-auto">
                <table class="table">
                    <tbody>
                        @foreach (var login in Model.CurrentLogins)
                        {
                            <tr>
                                <td id="@($"login-provider-{login.LoginProvider}")" class="font-medium">@login.ProviderDisplayName</td>
                                <td class="text-right">
                                    @if (Model.ShowRemoveButton)
                                    {
                                        <form id="@($"remove-login-{login.LoginProvider}")" asp-page-handler="RemoveLogin" method="post">
                                            <input asp-for="@login.LoginProvider" name="LoginProvider" type="hidden" />
                                            <input asp-for="@login.ProviderKey" name="ProviderKey" type="hidden" />
                                            <button type="submit" class="btn btn-error btn-xs" title="Від'єднати @login.ProviderDisplayName">Від'єднати</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (Model.OtherLogins?.Count > 0)
{
    <div class="card bg-base-100 border border-base-200 shadow-sm">
        <div class="card-body">
            <h4 class="font-semibold mb-3">Додати інший сервіс</h4>
            <form id="link-login-form" asp-page-handler="LinkLogin" method="post" class="flex flex-wrap gap-3">
                <div id="socialLoginList" class="flex flex-wrap gap-3">
                    @foreach (var provider in Model.OtherLogins)
                    {
                        <button id="@($"link-login-button-{provider.Name}")" type="submit" class="btn btn-outline btn-sm" name="provider" value="@provider.Name"
                                title="Увійти через @provider.DisplayName">@provider.DisplayName</button>
                    }
                </div>
            </form>
        </div>
    </div>
}
