@using System.Security.Claims
@using StudentParliamentSystem.Core.Aggregates.Role

@{
    ViewData["Title"] = "Панель керування";
    var isSuperAdmin = User.IsInRole(nameof(RoleName.SuperAdmin));
    var canManageCoworking = isSuperAdmin || User.IsInRole(nameof(RoleName.CoworkingDepartmentMember));
    var firstName = User.FindFirstValue(ClaimTypes.GivenName) ?? User.Identity?.Name ?? "Адміністратор";
}

<div class="min-h-[60vh] flex flex-col justify-center items-start max-w-3xl">
    <div class="mb-2">
        <span class="badge badge-primary badge-lg font-semibold mb-4">
            @(isSuperAdmin ? "Супер-Адміністратор" : "Учасник Парламенту")
        </span>
    </div>
    <h1 class="text-5xl md:text-6xl font-black mb-4 leading-tight">
        Вітаємо, <span class="text-primary">@firstName</span>!
    </h1>
    <p class="text-xl text-base-content/70 mb-10 max-w-xl">
        Це панель керування Студентського Парламенту. Звідси ви можете управляти департаментами, заходами та — якщо маєте повний доступ — користувачами системи.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 w-full">
        @if (isSuperAdmin)
        {
            <a asp-action="Users" class="card bg-base-100 border border-base-200 shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all group">
                <div class="card-body">
                    <div class="w-12 h-12 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-4 group-hover:bg-primary group-hover:text-primary-content transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
                    </div>
                    <h2 class="card-title font-bold text-xl">Користувачі</h2>
                    <p class="text-base-content/60 text-sm">Перегляд, редагування ролей та управління доступом.</p>
                </div>
            </a>

            <a asp-action="Departments" class="card bg-base-100 border border-base-200 shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all group">
                <div class="card-body">
                    <div class="w-12 h-12 rounded-2xl bg-secondary/10 text-secondary flex items-center justify-center mb-4 group-hover:bg-secondary group-hover:text-secondary-content transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>
                    </div>
                    <h2 class="card-title font-bold text-xl">Департаменти</h2>
                    <p class="text-base-content/60 text-sm">Управління складом та керівництвом департаментів.</p>
                </div>
            </a>
        }
        else
        {
            <div class="card bg-base-100 border border-base-200 shadow-xl">
                <div class="card-body">
                    <div class="w-12 h-12 rounded-2xl bg-secondary/10 text-secondary flex items-center justify-center mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>
                    </div>
                    <h2 class="card-title font-bold text-xl">Мій Департамент</h2>
                    <p class="text-base-content/60 text-sm">Ви маєте доступ до сторінки вашого департаменту через бічну навігацію.</p>
                </div>
            </div>
        }

        <a asp-controller="Events" asp-action="Index" class="card bg-base-100 border border-base-200 shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all group">
            <div class="card-body">
                <div class="w-12 h-12 rounded-2xl bg-accent/10 text-accent flex items-center justify-center mb-4 group-hover:bg-accent group-hover:text-accent-content transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
                </div>
                <h2 class="card-title font-bold text-xl">Заходи</h2>
                <p class="text-base-content/60 text-sm">Переглянути каталог опублікованих подій.</p>
            </div>
        </a>

        @if (canManageCoworking)
        {
            <a asp-action="CoworkingManagement" class="card bg-base-100 border border-base-200 shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all group">
                <div class="card-body">
                    <div class="w-12 h-12 rounded-2xl bg-warning/10 text-warning flex items-center justify-center mb-4 group-hover:bg-warning group-hover:text-warning-content transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H21M4.5 21H3m1.5 0H9m-4.5 0V7.5A2.25 2.25 0 016.75 5.25h10.5A2.25 2.25 0 0119.5 7.5V21" /></svg>
                    </div>
                    <h2 class="card-title font-bold text-xl">Коворкінг</h2>
                    <p class="text-base-content/60 text-sm">Модерація запитів на бронювання простору.</p>
                </div>
            </a>
        }
    </div>

    @if (isSuperAdmin)
    {
        <div class="mt-8 flex gap-4 w-full">
            <form asp-action="SeedFakeData" method="post" class="w-full sm:w-auto">
                <button type="submit" class="btn btn-warning shadow-lg w-full sm:w-auto" onclick="return confirm('Ця дія створить тестові дані. Продовжити?');">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                    Заповнити тестовими даними (Seed)
                </button>
            </form>
        </div>
    }
</div>
