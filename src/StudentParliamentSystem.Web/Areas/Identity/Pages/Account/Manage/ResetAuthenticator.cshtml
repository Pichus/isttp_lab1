@page
@model ResetAuthenticatorModel
@{
    ViewData["Title"] = "Скидання ключа автентифікатора";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3 class="text-xl font-semibold mb-4">@ViewData["Title"]</h3>

<div class="alert alert-warning mb-6" role="alert">
    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
    <div>
        <p class="font-bold">Якщо ви скинете ключ, застосунок-автентифікатор перестане працювати до повторного налаштування.</p>
        <p>Ця дія вимикає 2FA до підтвердження нового застосунку. Якщо ви не завершите налаштування, можете втратити доступ до акаунту.</p>
    </div>
</div>

<form id="reset-authenticator-form" method="post">
    <button id="reset-authenticator-button" class="btn btn-error" type="submit">Скинути ключ автентифікатора</button>
</form>
