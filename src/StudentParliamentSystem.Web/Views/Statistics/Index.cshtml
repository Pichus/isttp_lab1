@using StudentParliamentSystem.Api.Controllers
@model StudentParliamentSystem.Api.Controllers.StatisticsViewModel
@{
    ViewData["Title"] = "Статистика та Аналітика";
    
    var maxEvents = Model.DepartmentActivities.Any() ? Model.DepartmentActivities.Max(d => d.EventsCount) : 0;
    if (maxEvents == 0) maxEvents = 1;
    
    var colors = new[] { "bg-primary", "bg-secondary", "bg-accent", "bg-success", "bg-warning", "bg-info" };
}

<div class="mb-8 flex justify-between items-end flex-wrap gap-4">
    <div>
        <h1 class="text-4xl font-black mb-2">Статистика</h1>
        <p class="text-base-content/70">Загальна інформація про діяльність Студентського Парламенту.</p>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="stat bg-base-100 shadow-xl rounded-2xl border border-base-200">
        <div class="stat-figure text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-8 h-8 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
        </div>
        <div class="stat-title">Активних Членів СПФ</div>
        <div class="stat-value text-primary">@Model.ActiveMembersCount</div>
        <div class="stat-desc">Зареєстровані користувачі</div>
    </div>
    
    <div class="stat bg-base-100 shadow-xl rounded-2xl border border-base-200">
        <div class="stat-figure text-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-8 h-8 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <div class="stat-title">Проведених Заходів</div>
        <div class="stat-value text-secondary">@Model.ConductedEventsCount</div>
        <div class="stat-desc">Загалом</div>
    </div>
    
    <div class="stat bg-base-100 shadow-xl rounded-2xl border border-base-200">
        <div class="stat-figure text-accent">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-8 h-8 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
        </div>
        <div class="stat-title">Годин Коворкінгу</div>
        <div class="stat-value text-accent">@Model.CoworkingHours</div>
        <div class="stat-desc">Загалом заброньовано</div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <div class="bg-base-100 p-6 rounded-3xl shadow-xl border border-base-200">
        <h3 class="text-xl font-bold mb-4">Активність Департаментів (Заходи)</h3>
        <div class="h-64 bg-base-200 rounded-xl flex items-end justify-around p-4 items-center border border-dashed border-base-300">
            @for(int i = 0; i < Model.DepartmentActivities.Count; i++)
            {
                var dep = Model.DepartmentActivities[i];
                var heightPx = (int)((dep.EventsCount / (double)maxEvents) * 160) + 20;
                var colorClass = colors[i % colors.Length];
                <div class="flex flex-col items-center gap-2" title="@dep.EventsCount заходів">
                    <div class="w-12 @colorClass rounded-t-sm hover:opacity-80 transition-opacity cursor-pointer" style="height: @(heightPx)px"></div>
                    <div class="text-xs font-bold text-center max-w-[60px] truncate" title="@dep.Name">@dep.Name</div>
                </div>
            }
            @if(!Model.DepartmentActivities.Any())
            {
                <span class="text-base-content/50">Немає даних</span>
            }
        </div>
    </div>

    <div class="bg-base-100 p-6 rounded-3xl shadow-xl border border-base-200">
        <h3 class="text-xl font-bold mb-4">Топ Заходів за Заявками</h3>
        <div class="overflow-x-auto">
          <table class="table table-sm w-full">
            <thead>
              <tr class="bg-base-200 text-base-content text-sm">
                <th>Назва</th>
                <th>Департамент</th>
                <th>Заявок</th>
              </tr>
            </thead>
            <tbody>
              @foreach(var evt in Model.TopEvents)
              {
                  <tr>
                    <td class="font-bold">@evt.Name</td>
                    <td>@evt.DepartmentName</td>
                    <td>@evt.ParticipantsCount</td>
                  </tr>
              }
              @if(!Model.TopEvents.Any())
              {
                  <tr>
                      <td colspan="3" class="text-center text-base-content/50 py-4">Немає даних</td>
                  </tr>
              }
            </tbody>
          </table>
        </div>
    </div>
</div>
