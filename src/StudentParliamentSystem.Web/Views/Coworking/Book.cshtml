@{
    ViewData["Title"] = "Бронювання Коворкінгу";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-8 text-center">
        <h1 class="text-4xl font-black mb-2">Бронювання Місця</h1>
        <p class="text-base-content/70">Виберіть зручний час та вкажіть мету бронювання.</p>
    </div>

    <div class="bg-base-100 shadow-xl rounded-3xl border border-base-200 p-8">
        <form action="/Coworking" method="post" class="space-y-6">
            
            <div class="grid grid-cols-2 gap-4">
                <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text font-bold">Дата</span>
                    </label>
                    <input type="date" class="input input-bordered w-full bg-base-200/50" required />
                </div>
                 <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text font-bold">Тип місця</span>
                    </label>
                    <select class="select select-bordered w-full bg-base-200/50">
                        <option>Індивідуальне місце (Читалка)</option>
                        <option>Великий стіл (Коворкінг)</option>
                        <option>Зона пуфів</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text font-bold">Час Початку</span>
                    </label>
                    <input type="time" class="input input-bordered w-full bg-base-200/50" required />
                </div>
                <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text font-bold">Час Завершення</span>
                    </label>
                    <input type="time" class="input input-bordered w-full bg-base-200/50" required />
                </div>
            </div>

             <!-- Conflict Alert Mock -->
            <div class="alert alert-info shadow-sm border border-info/20">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <div>
                <h3 class="font-bold text-sm">Зверніть увагу: ліміт 12 годин!</h3>
                <div class="text-xs">Ви можете бронювати місце на строк до 1 місяця вперед. Максимальна тривалість безперервного сеансу становить 12 годин.</div>
              </div>
            </div>

            <div class="form-control w-full">
                <label class="label">
                    <span class="label-text font-bold">Мета бронювання / Деталі <span class="text-error">*</span></span>
                </label>
                <textarea class="textarea textarea-bordered h-24 bg-base-200/50" placeholder="Наприклад: Підготовка до лаби з ІСТТП, 3 людини" required></textarea>
            </div>

            <div class="divider"></div>

            <div class="flex justify-between items-center">
                 <a href="/Coworking" class="btn btn-ghost rounded-full px-6">Скасувати</a>
                 <button type="submit" class="btn btn-secondary btn-lg rounded-full px-10 shadow-lg shadow-secondary/30">Надіслати Запит</button>
            </div>
        </form>
    </div>
</div>
