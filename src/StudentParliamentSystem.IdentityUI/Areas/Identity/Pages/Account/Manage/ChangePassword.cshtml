@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Зміна паролю";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3 class="text-xl font-semibold mb-4">@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="card bg-base-100 border border-base-200 shadow-sm">
    <div class="card-body">
        <form id="change-password-form" method="post" class="flex flex-col gap-4 max-w-md">
            <div asp-validation-summary="ModelOnly" class="alert alert-error text-sm" role="alert"></div>

            <div class="form-control">
                <label asp-for="Input.OldPassword" class="label"><span class="label-text font-medium">Поточний пароль</span></label>
                <input asp-for="Input.OldPassword" class="input input-bordered w-full" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.OldPassword" class="label-text-alt text-error mt-1"></span>
            </div>

            <div class="form-control">
                <label asp-for="Input.NewPassword" class="label"><span class="label-text font-medium">Новий пароль</span></label>
                <input asp-for="Input.NewPassword" class="input input-bordered w-full" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.NewPassword" class="label-text-alt text-error mt-1"></span>
            </div>

            <div class="form-control">
                <label asp-for="Input.ConfirmPassword" class="label"><span class="label-text font-medium">Підтвердження паролю</span></label>
                <input asp-for="Input.ConfirmPassword" class="input input-bordered w-full" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.ConfirmPassword" class="label-text-alt text-error mt-1"></span>
            </div>

            <button type="submit" class="btn btn-primary">Змінити пароль</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
