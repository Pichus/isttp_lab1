@{
    ViewData["Title"] = "Деталі Заходу";
}

<div class="max-w-4xl mx-auto">
    <!-- Breadcrumbs -->
    <div class="text-sm breadcrumbs mb-6">
        <ul>
            <li><a href="/">Головна</a></li> 
            <li><a href="/Events">Заходи</a></li> 
            <li class="font-semibold text-base-content">Деталі Заходу</li>
        </ul>
    </div>

    <!-- Event Banner -->
    <div class="w-full h-64 md:h-96 rounded-3xl bg-base-300 mb-8 relative overflow-hidden shadow-lg border border-base-200">
        <div class="absolute inset-0 bg-gradient-to-tr from-primary/40 to-secondary/40 flex items-center justify-center">
             <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-16 h-16 text-base-content/40"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" /></svg>
        </div>
    </div>

    <!-- Event Header & Actions -->
    <div class="flex flex-col md:flex-row justify-between items-start gap-6 mb-8">
        <div class="flex-1">
            <div class="flex gap-2 mb-3">
                <span class="badge badge-primary badge-outline font-semibold">Відкрито реєстрацію</span>
                <span class="badge badge-ghost font-semibold">Вечірка</span>
            </div>
            <h1 class="text-4xl md:text-5xl font-black mb-4">Посвята Першокурсників</h1>
            <p class="text-xl text-base-content/80 font-light mb-6">Найбільша подія осені. Знайомства, музика та незабутні враження чекають на тебе.</p>
            
            <div class="flex flex-wrap gap-6 mb-6">
                <div class="flex items-center gap-3 bg-base-200 px-4 py-2 rounded-xl">
                    <div class="p-2 bg-primary/10 rounded-lg text-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
                    </div>
                    <div>
                        <div class="text-xs text-base-content/60 uppercase font-semibold">Дата та час</div>
                        <div class="font-medium">12 жовтня 2026, 18:00</div>
                    </div>
                </div>

                <div class="flex items-center gap-3 bg-base-200 px-4 py-2 rounded-xl">
                    <div class="p-2 bg-secondary/10 rounded-lg text-secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
                    </div>
                    <div>
                        <div class="text-xs text-base-content/60 uppercase font-semibold">Локація</div>
                        <div class="font-medium">Малий актовий зал</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Call to Action Box -->
        <div class="w-full md:w-80 bg-base-100 p-6 rounded-2xl shadow-xl border border-base-200 flex flex-col gap-4 sticky top-6">
            <div class="flex justify-between items-center pb-4 border-b border-base-200">
                <div>
                    <div class="text-sm text-base-content/60 mb-1">Вільних місць</div>
                    <div class="text-2xl font-bold">120 <span class="text-sm font-normal text-base-content/50">/ 300</span></div>
                </div>
            </div>
            
            <!-- Registration Action (Usecase UC_Register) -->
            <button class="btn btn-primary btn-lg w-full rounded-xl shadow-lg shadow-primary/30 mt-2">
                Зареєструватися
            </button>
            <p class="text-xs text-center text-base-content/50">Реєстрація триває до 11 жовтня</p>

            <div class="divider my-0">АБО</div>

            <!-- Join Org Team Action (Usecase UC_JoinOrg) -->
            <button class="btn btn-outline btn-secondary w-full rounded-xl" onclick="joinOrg_modal.showModal()">
                Долучитися до Оргкомітету
            </button>
            
            <!-- Admin Edit Action (UC_CreateEvent / Edit) -->
            <div class="mt-4 pt-4 border-t border-base-200">
                 <a href="/Events/Edit/1" class="btn btn-ghost btn-sm w-full text-base-content/60 hover:text-base-content">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" /></svg>
                    Редагувати івент (Адмін)
                </a>
            </div>
        </div>
    </div>

    <!-- Event Description -->
    <div class="prose prose-lg max-w-none text-base-content/80 mb-12">
        <h3 class="text-2xl font-bold text-base-content mb-4">Про Захід</h3>
        <p>
            Запрошуємо всіх першокурсників, а також студентів старших курсів на традиційну вечірку-посвяту. 
            Це ідеальна нагода завести нові знайомства, знайти друзів за інтересами та весело провести час подалі від конспектів.
        </p>
        <p>
            У програмі:
        </p>
        <ul>
            <li>Виступи студентських гуртів</li>
            <li>Інтерактиви від ведучого</li>
            <li>Розіграші мерчу СПФ</li>
            <li>DJ сет до пізньої ночі</li>
        </ul>
        <p>Зверніть увагу, що вхід виключно за попередньою реєстрацією та за наявності студентського квитка!</p>
    </div>
</div>

<!-- Join Org Committee Modal -->
<dialog id="joinOrg_modal" class="modal modal-bottom sm:modal-middle">
  <div class="modal-box p-8 rounded-3xl">
    <h3 class="font-bold text-2xl mb-2">Заявка в Оргкомітет</h3>
    <p class="py-2 text-base-content/70">Хочеш допомогти в організації та отримати унікальний досвід? Заповни заявку!</p>
    
    <div class="form-control w-full mt-4">
        <label class="label"><span class="label-text font-medium">Бажана роль</span></label>
        <select class="select select-bordered w-full">
            <option disabled selected>Обери роль в команді</option>
            <option>SMM (соцмережі)</option>
            <option>Дизайнер</option>
            <option>Технічна підтримка (звук/світло)</option>
            <option>Волонтер на вході</option>
        </select>
    </div>

     <div class="form-control w-full mt-4">
        <label class="label"><span class="label-text font-medium">Коротко про твій досвід/мотивацію</span></label>
        <textarea class="textarea textarea-bordered h-24" placeholder="Напишіть декілька слів..."></textarea>
    </div>

    <div class="modal-action mt-8">
      <form method="dialog" class="flex gap-2 w-full justify-end">
        <button class="btn btn-ghost rounded-xl">Скасувати</button>
        <button class="btn btn-primary rounded-xl px-8">Надіслати заявку</button>
      </form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
