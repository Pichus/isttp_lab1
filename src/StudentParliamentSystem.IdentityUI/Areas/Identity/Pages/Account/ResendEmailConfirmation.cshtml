@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Повторна відправка підтвердження";
}

<div class="flex justify-center items-start py-8">
    <div class="card bg-base-100 shadow-xl border border-base-200 w-full max-w-md">
        <div class="card-body gap-6">
            <div class="text-center">
                <h1 class="text-3xl font-bold">@ViewData["Title"]</h1>
                <p class="text-base-content/60 mt-1">Введіть свій email</p>
            </div>

            <form method="post" class="flex flex-col gap-4">
                <div asp-validation-summary="All" class="alert alert-error text-sm" role="alert"></div>

                <div class="form-control">
                    <label asp-for="Input.Email" class="label"><span class="label-text font-medium">Email</span></label>
                    <input asp-for="Input.Email" class="input input-bordered w-full" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="label-text-alt text-error mt-1"></span>
                </div>

                <button type="submit" class="btn btn-primary w-full">Надіслати повторно</button>

                <p class="text-center text-sm">
                    <a asp-page="./Login" class="link link-primary">Повернутись до входу</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
