@page
@model LockoutModel
@{
    ViewData["Title"] = "Акаунт заблоковано";
}

<div class="flex justify-center items-start py-12">
    <div class="card bg-base-100 shadow-xl border border-warning/30 w-full max-w-md">
        <div class="card-body items-center text-center gap-4">
            <div class="w-16 h-16 rounded-full bg-warning/10 flex items-center justify-center text-warning">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                </svg>
            </div>
            <h1 class="text-2xl font-bold text-warning">@ViewData["Title"]</h1>
            <p class="text-base-content/70">Цей акаунт заблоковано. Будь ласка, спробуйте пізніше.</p>
            <a href="/" class="btn btn-outline mt-2">На головну</a>
        </div>
    </div>
</div>
