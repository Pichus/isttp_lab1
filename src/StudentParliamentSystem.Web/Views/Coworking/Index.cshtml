@model IEnumerable<StudentParliamentSystem.Core.Aggregates.CoworkingBooking.CoworkingBookingSlot>
@using StudentParliamentSystem.Api.Configurations

@{
    ViewData["Title"] = "КНУ Коворкінг та Читалка";
    var schedule = Model.OrderBy(s => s.StartTime).ToList();
}

<div class="mb-8 flex justify-between items-end flex-wrap gap-4">
    <div>
        <h1 class="text-4xl font-black mb-2">Коворкінг Простір</h1>
        <p class="text-base-content/70">Плануйте свій розклад та бронюйте місця для ваших заходів.</p>
    </div>
    <div class="flex gap-2">
        <a asp-action="RequestBooking" class="btn btn-primary shadow-lg shadow-primary/30">
             <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 mr-1"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
            Забронювати для заходу
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success mb-6 rounded-2xl shadow-sm">
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2">
        <div class="bg-base-100 p-6 rounded-3xl border border-base-200 shadow-xl">
            <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-primary"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
                Зайняті слоти
            </h2>

            @if (!schedule.Any())
            {
                <div class="text-center py-12 opacity-50">
                    <p>Наразі немає підтверджених бронювань.</p>
                </div>
            }
            else
            {
                <div class="space-y-4">
                    @foreach (var slot in schedule)
                    {
                        <div class="flex items-center gap-4 p-4 rounded-2xl border border-base-200 hover:bg-base-200/50 transition-colors">
                            <div class="flex flex-col items-center justify-center min-w-[100px] border-r border-base-200 pr-4">
                                <span class="text-sm font-bold">@slot.StartTime.ToLocalTime().ToString("dd.MM")</span>
                                <span class="text-xs opacity-60">@slot.StartTime.ToLocalTime().ToString("HH:mm") - @slot.EndTime.ToLocalTime().ToString("HH:mm")</span>
                            </div>
                            <div class="flex-1">
                                <h3 class="font-bold">@slot.EventTitle</h3>
                                <span class="badge @(slot.StatusName == "Approved" ? "badge-success" : "badge-warning") badge-sm">
                                    @(slot.StatusName == "Approved" ? "Підтверджено" : "Очікує")
                                </span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="lg:col-span-1">
        <div class="card bg-secondary/10 border border-secondary/20 rounded-3xl">
            <div class="card-body">
                <h3 class="card-title text-secondary">Правила коворкінгу</h3>
                <ul class="space-y-2 text-sm opacity-80 list-disc list-inside">
                    <li>Бронювання можливе лише для існуючих заходів.</li>
                    <li>Захід має бути створений вами.</li>
                    <li>Максимальна тривалість: 12 годин.</li>
                    <li>Бронювання підлягає модерації.</li>
                </ul>
            </div>
        </div>
    </div>
</div>
