@page
@model ShowRecoveryCodesModel
@{
    ViewData["Title"] = "Коди відновлення";
    ViewData["ActivePage"] = "TwoFactorAuthentication";
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3 class="text-xl font-semibold mb-4">@ViewData["Title"]</h3>

<div class="alert alert-warning mb-6" role="alert">
    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
    <div>
        <p class="font-bold">Зберігайте коди в надійному місці.</p>
        <p>Якщо ви втратите пристрій і не матимете цих кодів, ви втратите доступ до акаунту.</p>
    </div>
</div>

<div class="card bg-base-100 border border-base-200 shadow-sm">
    <div class="card-body">
        <div class="grid grid-cols-2 gap-2 font-mono text-sm">
            @for (var row = 0; row < Model.RecoveryCodes.Length; row += 2)
            {
                <code class="recovery-code bg-base-200 rounded px-3 py-2">@Model.RecoveryCodes[row]</code>
                <code class="recovery-code bg-base-200 rounded px-3 py-2">@Model.RecoveryCodes[row + 1]</code>
            }
        </div>
    </div>
</div>
