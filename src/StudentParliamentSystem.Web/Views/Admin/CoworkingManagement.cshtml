@model StudentParliamentSystem.Core.Abstractions.PagedResult<StudentParliamentSystem.Core.Aggregates.CoworkingBooking.CoworkingBookingPreview>
@{
    ViewData["Title"] = "Керування Коворкінгом";
    var currentStatus = ViewBag.Status as string;
}

<div class="mb-8">
    <h1 class="text-4xl font-black mb-2">Керування Коворкінгом</h1>
    <p class="text-base-content/70">Модерація запитів на бронювання простору.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success mb-6 rounded-2xl shadow-sm">
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

<div class="bg-base-100 shadow-xl rounded-3xl border border-base-200 p-6 mb-8">
    <h2 class="text-2xl font-bold mb-4">Генерація Подання</h2>
    <form asp-action="GenerateReport" method="post" class="flex flex-col gap-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="form-control">
                <label class="label p-1"><span class="label-text font-bold text-xs">Початок</span></label>
                <input type="date" name="reportStart" class="input input-bordered input-sm" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-control">
                <label class="label p-1"><span class="label-text font-bold text-xs">Кінець</span></label>
                <input type="date" name="reportEnd" class="input input-bordered input-sm" required value="@DateTime.Now.AddDays(7).ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-control">
                <label class="label p-1"><span class="label-text font-bold text-xs">Дата на документі</span></label>
                <input type="date" name="documentDate" class="input input-bordered input-sm" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-control">
                <label class="label p-1"><span class="label-text font-bold text-xs">Від кого (ПІБ)</span></label>
                <input type="text" name="senderName" class="input input-bordered input-sm" required value="@User.Identity?.Name" placeholder="Іваненко Іван" />
            </div>
        </div>
        
        <div class="form-control">
            <label class="label p-1"><span class="label-text font-bold text-xs">Отримувач</span></label>
            <select name="receiverIdOrCustom" id="receiverSelect" class="select select-bordered select-sm w-full" onchange="document.getElementById('customReceiverDiv').style.display = this.value === 'custom' ? 'block' : 'none'">
                @if(ViewBag.Receivers != null)
                {
                    foreach(var rec in ViewBag.Receivers)
                    {
                        if(rec.IsDefault) {
                            <option value="@rec.Id" selected>@rec.Name (@rec.Position)</option>
                        } else {
                            <option value="@rec.Id">@rec.Name (@rec.Position)</option>
                        }
                    }
                }
                <option value="custom">Свій варіант...</option>
            </select>
        </div>
        
        <div class="form-control" id="customReceiverDiv" style="display: none;">
            <label class="label p-1"><span class="label-text font-bold text-xs">Повний титул отримувача (давальний відмінок)</span></label>
            <textarea name="customReceiverTitle" class="textarea textarea-bordered textarea-sm w-full" placeholder="В.о. декана..."></textarea>
        </div>

        <button type="submit" class="btn btn-primary mt-2">
            Згенерувати Подання
        </button>
    </form>
</div>

<div class="bg-base-100 shadow-xl rounded-3xl border border-base-200 p-6 mb-8">
    <div class="flex justify-between items-center mb-4">
        <h2 class="text-2xl font-bold">Отримувачі Подань</h2>
        <button class="btn btn-sm btn-outline" onclick="document.getElementById('createReceiverModal').showModal()">Додати</button>
    </div>
    <div class="overflow-x-auto">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Ім'я</th>
                    <th>Посада</th>
                    <th>За замовчуванням</th>
                    <th>Дії</th>
                </tr>
            </thead>
            <tbody>
                @if(ViewBag.Receivers != null)
                {
                    foreach(var rec in ViewBag.Receivers)
                    {
                        <tr>
                            <td>@rec.Name</td>
                            <td>@rec.Position</td>
                            <td>@(rec.IsDefault ? "Так" : "Ні")</td>
                            <td>
                                <button class="btn btn-xs btn-warning" onclick="document.getElementById('editReceiverModal-@rec.Id').showModal()">Редагувати</button>
                                <form asp-action="DeleteDocumentReceiver" asp-route-id="@rec.Id" method="post" style="display:inline">
                                    <button class="btn btn-xs btn-error" onclick="return confirm('Ви впевнені?')">Видалити</button>
                                </form>

                                <dialog id="editReceiverModal-@rec.Id" class="modal">
                                    <div class="modal-box text-left whitespace-normal">
                                        <h3 class="font-bold text-lg">Редагувати отримувача</h3>
                                        <form asp-action="EditDocumentReceiver" method="post">
                                            <input type="hidden" name="id" value="@rec.Id" />
                                            <div class="form-control mt-4">
                                                <label class="label"><span class="label-text">Ім'я (ПІБ)</span></label>
                                                <input type="text" name="name" required class="input input-bordered" value="@rec.Name" />
                                            </div>
                                            <div class="form-control mt-4">
                                                <label class="label"><span class="label-text">Посада</span></label>
                                                <input type="text" name="position" required class="input input-bordered" value="@rec.Position" />
                                            </div>
                                            <div class="form-control mt-4">
                                                <label class="label"><span class="label-text">Повний титул (давальний відмінок)</span></label>
                                                <textarea name="fullTitle" required class="textarea textarea-bordered h-24">@rec.FullTitle</textarea>
                                            </div>
                                            <div class="form-control mt-4 flex-row items-center gap-2">
                                                <input type="checkbox" name="isDefault" value="true" class="checkbox" @(rec.IsDefault ? "checked" : "") />
                                                <label class="label cursor-pointer"><span class="label-text">За замовчуванням</span></label>
                                            </div>
                                            <div class="modal-action">
                                                <button type="button" class="btn" onclick="this.closest('dialog').close()">Скасувати</button>
                                                <button type="submit" class="btn btn-primary">Зберегти</button>
                                            </div>
                                        </form>
                                    </div>
                                </dialog>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<dialog id="createReceiverModal" class="modal">
    <div class="modal-box">
        <h3 class="font-bold text-lg">Новий отримувач</h3>
        <form asp-action="CreateDocumentReceiver" method="post">
            <div class="form-control mt-4">
                <label class="label"><span class="label-text">Ім'я (ПІБ)</span></label>
                <input type="text" name="name" required class="input input-bordered" />
            </div>
            <div class="form-control mt-4">
                <label class="label"><span class="label-text">Посада</span></label>
                <input type="text" name="position" required class="input input-bordered" />
            </div>
            <div class="form-control mt-4">
                <label class="label"><span class="label-text">Повний титул (давальний відмінок)</span></label>
                <textarea name="fullTitle" required class="textarea textarea-bordered h-24" placeholder="Виконуючому обов'язки..."></textarea>
            </div>
            <div class="form-control mt-4 flex-row items-center gap-2">
                <input type="checkbox" name="isDefault" value="true" class="checkbox" />
                <label class="label cursor-pointer"><span class="label-text">За замовчуванням</span></label>
            </div>
            <div class="modal-action">
                <button type="button" class="btn" onclick="this.closest('dialog').close()">Скасувати</button>
                <button type="submit" class="btn btn-primary">Зберегти</button>
            </div>
        </form>
    </div>
</dialog>

<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-4">
    <div class="flex flex-wrap gap-2">
        <a asp-action="CoworkingManagement" asp-route-status="" class="btn btn-sm btn-ghost @(string.IsNullOrEmpty(currentStatus) ? "btn-active" : "")">Всі</a>
        <a asp-action="CoworkingManagement" asp-route-status="Pending" class="btn btn-sm btn-ghost @(currentStatus == "Pending" ? "btn-active" : "")">Очікують</a>
        <a asp-action="CoworkingManagement" asp-route-status="Approved" class="btn btn-sm btn-ghost @(currentStatus == "Approved" ? "btn-active" : "")">Підтверджені</a>
        <a asp-action="CoworkingManagement" asp-route-status="Rejected" class="btn btn-sm btn-ghost @(currentStatus == "Rejected" ? "btn-active" : "")">Відхилені</a>
    </div>
</div>

<div class="overflow-x-auto bg-base-100 rounded-3xl shadow-xl border border-base-200">
    <table class="table table-zebra w-full">
        <thead>
            <tr class="bg-base-200">
                <th>Захід / Організатор</th>
                <th>Дата та Час</th>
                <th>Статус</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model.Items)
            {
                <tr>
                    <td>
                        <div class="font-bold">@booking.EventTitle</div>
                        <div class="text-xs opacity-60">@booking.RequesterName</div>
                        @if (!string.IsNullOrEmpty(booking.Notes))
                        {
                            <div class="mt-1 p-2 bg-base-200 rounded text-xs italic">
                                "@booking.Notes"
                            </div>
                        }
                    </td>
                    <td>
                        <div class="text-sm">@booking.StartTime.ToLocalTime().ToString("dd MMM, HH:mm")</div>
                        <div class="text-sm opacity-60">@booking.EndTime.ToLocalTime().ToString("dd MMM, HH:mm")</div>
                    </td>
                    <td>
                        <span class="badge @(booking.StatusName switch { "Approved" => "badge-success", "Rejected" => "badge-error", _ => "badge-warning" }) badge-sm font-bold">
                            @booking.StatusName
                        </span>
                    </td>
                    <td>
                        <div class="flex gap-2">
                            @if (booking.StatusName == "Pending")
                            {
                                <button class="btn btn-success btn-xs" onclick="document.getElementById('approve-modal-@booking.Id').showModal()">Підтвердити</button>

                                <dialog id="approve-modal-@booking.Id" class="modal">
                                    <div class="modal-box overflow-visible">
                                        <h3 class="font-bold text-lg">Підтвердити бронювання</h3>
                                        <form asp-action="ApproveBooking" asp-route-id="@booking.Id" method="post">
                                            <div class="form-control mt-4">
                                                <label class="label"><span class="label-text font-semibold">Оберіть адміністратора</span></label>
                                                <select name="managerId" class="select select-bordered w-full" required>
                                                    <option disabled selected value="">Оберіть...</option>
                                                    @if(ViewBag.CoworkingMembers != null)
                                                    {
                                                        foreach(var member in ViewBag.CoworkingMembers)
                                                        {
                                                            <option value="@member.Id">@member.FirstName @member.LastName (@member.Email)</option>
                                                        }
                                                    }
                                                </select>
                                            </div>
                                            <div class="modal-action">
                                                <button type="button" class="btn" onclick="this.closest('dialog').close()">Скасувати</button>
                                                <button type="submit" class="btn btn-success">Підтвердити</button>
                                            </div>
                                        </form>
                                    </div>
                                </dialog>

                                <button class="btn btn-error btn-xs" onclick="document.getElementById('reject-modal-@booking.Id').showModal()">Відхилити</button>

                                <dialog id="reject-modal-@booking.Id" class="modal">
                                    <div class="modal-box">
                                        <h3 class="font-bold text-lg">Відхилити бронювання?</h3>
                                        <form asp-action="RejectBooking" asp-route-id="@booking.Id" method="post">
                                            <div class="form-control mt-4">
                                                <label class="label"><span class="label-text">Причина (опціонально)</span></label>
                                                <textarea name="notes" class="textarea textarea-bordered h-24" placeholder="Напишіть причину відмови..."></textarea>
                                            </div>
                                            <div class="modal-action">
                                                <button type="button" class="btn" onclick="this.closest('dialog').close()">Скасувати</button>
                                                <button type="submit" class="btn btn-error">Відхилити</button>
                                            </div>
                                        </form>
                                    </div>
                                </dialog>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="text-center py-10 opacity-60">
            <p>Запитів не знайдено.</p>
        </div>
    }
</div>

@if (Model.TotalPages > 1)
{
    <div class="flex flex-col items-center mt-6 gap-3">
        <div class="join shadow-sm">
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <a asp-action="CoworkingManagement" asp-route-page="@i" asp-route-status="@currentStatus"
                   class="join-item btn btn-sm @(i == Model.CurrentPage ? "btn-active" : "")">@i</a>
            }
        </div>
    </div>
}
