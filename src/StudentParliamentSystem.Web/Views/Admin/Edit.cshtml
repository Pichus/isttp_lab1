@model StudentParliamentSystem.Api.Models.UpdateUserViewModel

@{
    ViewData["Title"] = "Редагувати Користувача";
}

<div class="mb-8 flex justify-between items-end flex-wrap gap-4">
    <div>
        <h1 class="text-4xl font-black mb-2 flex items-center gap-3">
            Редагувати Користувача
            <span class="badge badge-lg badge-neutral">@Model.FirstName @Model.LastName</span>
        </h1>
        <p class="text-base-content/70">Оновлення персональних даних та ролей користувача.</p>
    </div>
    <div>
        <a asp-action="Users" class="btn btn-ghost border-base-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Назад до списку
        </a>
    </div>
</div>

<div class="bg-base-100 shadow-xl rounded-3xl border border-base-200 p-8 max-w-2xl">
    <form asp-action="Edit" class="space-y-6">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="alert alert-error shadow-sm rounded-2xl mb-4"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="form-control w-full">
                <label asp-for="FirstName" class="label">
                    <span class="label-text font-bold text-base">Ім'я</span>
                </label>
                <input asp-for="FirstName" class="input input-bordered w-full rounded-2xl focus:ring-primary" placeholder="Введіть ім'я" />
                <span asp-validation-for="FirstName" class="text-error text-sm mt-1"></span>
            </div>

            <div class="form-control w-full">
                <label asp-for="LastName" class="label">
                    <span class="label-text font-bold text-base">Прізвище</span>
                </label>
                <input asp-for="LastName" class="input input-bordered w-full rounded-2xl focus:ring-primary" placeholder="Введіть прізвище" />
                <span asp-validation-for="LastName" class="text-error text-sm mt-1"></span>
            </div>
        </div>

        <div class="form-control">
            <label class="label">
                <span class="label-text font-bold text-base">Ролі Користувача</span>
            </label>
            <div class="bg-base-200/50 rounded-2xl p-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
                @foreach (var role in Model.AvailableRoles)
                {
                    <label class="label cursor-pointer justify-start gap-3 hover:bg-base-200 rounded-xl px-3 transition-colors">
                        <input type="checkbox" name="Roles" value="@role" @(Model.Roles.Contains(role) ? "checked" : "") 
                               class="checkbox checkbox-primary rounded-lg" />
                        <span class="label-text font-medium">@role</span>
                    </label>
                }
            </div>
            <span asp-validation-for="Roles" class="text-error text-sm mt-1"></span>
        </div>

        <div class="pt-4 flex gap-4">
            <button type="submit" class="btn btn-primary rounded-2xl px-8">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Зберегти зміни
            </button>
        </div>
    </form>
</div>
