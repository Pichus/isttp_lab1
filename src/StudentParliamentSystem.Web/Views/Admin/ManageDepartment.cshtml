@using StudentParliamentSystem.Core.Aggregates.Role
@using System.Security.Claims
@model StudentParliamentSystem.Api.Models.Admin.ManageDepartmentViewModel

@{
    var dept = Model.Department;
    var isSuperAdmin = (bool)ViewBag.IsSuperAdmin;
    ViewData["Title"] = $"Управління: {dept?.Name}";

    var userIdStr = User.FindFirstValue(ClaimTypes.NameIdentifier);
    Guid.TryParse(userIdStr, out var currentUserId);
}

<div class="mb-8 flex justify-between items-end flex-wrap gap-4">
    <div>
        <h1 class="text-4xl font-black mb-2 flex items-center gap-3">
            @dept?.Name
            <span class="badge badge-lg badge-neutral">@Model.Users.TotalCount учасників</span>
        </h1>
        <p class="text-base-content/70">Управління учасниками, керівництвом та заходами департаменту.</p>
    </div>
    <div class="flex gap-2">
        <a asp-action="Departments" class="btn btn-outline">Назад</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success mb-6 rounded-2xl shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-error mb-6 rounded-2xl shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span>@TempData["ErrorMessage"]</span>
    </div>
}


<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12">
    <div class="lg:col-span-1 flex flex-col gap-6">
        <div class="card bg-base-100 shadow-xl border border-base-200">
            <div class="card-body">
                <h2 class="card-title text-lg font-bold">Додати учасника</h2>
                <form method="post" asp-action="AddMember" asp-route-id="@dept?.Id">
                    <div class="form-control">
                        <label class="label"><span class="label-text">Email користувача</span></label>
                        <input type="email" name="email" required placeholder="user@example.com" class="input input-bordered w-full" />
                    </div>
                    <div class="form-control mt-4">
                        <button type="submit" class="btn btn-primary w-full">Додати</button>
                    </div>
                </form>
            </div>
        </div>

        @if (isSuperAdmin)
        {
            <div class="card bg-base-100 shadow-xl border border-base-200">
                <div class="card-body">
                    <h2 class="card-title text-lg font-bold text-warning">Змінити Голову Департаменту</h2>
                    <p class="text-sm opacity-70">Лише для Супер-Адміністраторів</p>
                    <form method="post" asp-action="ChangeHead" asp-route-id="@dept?.Id">
                        <div class="form-control">
                            <label class="label"><span class="label-text">Новий Голова (Email)</span></label>
                            <input type="email" name="email" required placeholder="newhead@example.com" class="input input-bordered input-warning w-full" />
                        </div>
                        <div class="form-control mt-4">
                            <button type="submit" class="btn btn-warning w-full">Змінити Роль</button>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>

    <div class="lg:col-span-2">
        <div class="bg-base-100 shadow-xl rounded-3xl border border-base-200 p-6 mb-6">
            <form method="get" asp-action="ManageDepartment" asp-route-id="@dept?.Id" class="form-control w-full">
                <label class="label"><span class="label-text font-bold">Пошук учасника</span></label>
                <div class="input-group flex w-full">
                    <input type="text" name="query" value="@ViewBag.Query" placeholder="Ім'я або email" class="input input-bordered w-full rounded-r-none"/>
                    <button type="submit" class="btn btn-square btn-neutral rounded-l-none">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                    </button>
                </div>
            </form>
        </div>

        <div class="overflow-x-auto bg-base-100 rounded-3xl shadow-xl border border-base-200">
            <table class="table table-zebra w-full">
                <thead>
                <tr class="bg-base-200 text-sm">
                    <th>Користувач</th>
                    <th>Електронна пошта</th>
                    <th>Ролі</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var user in Model.Users.Items)
                {
                    <tr class="hover">
                        <td>
                            <div class="flex items-center space-x-3">
                                <div class="avatar placeholder">
                                    <div class="bg-neutral text-neutral-content rounded-full w-10">
                                        <span class="text-sm uppercase">@(user.FirstName.FirstOrDefault())@(user.LastName.FirstOrDefault())</span>
                                    </div>
                                </div>
                                <div class="font-bold">@user.FirstName @user.LastName</div>
                            </div>
                        </td>
                        <td class="text-sm">@user.Email</td>
                        <td>
                            <div class="flex flex-wrap gap-1">
                                @if (user.Roles != null && user.Roles.Any())
                                {
                                    @foreach (var role in user.Roles)
                                    {
                                        <span class="badge badge-success badge-sm font-bold">@role</span>
                                    }
                                }
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            @if (!Model.Users.Items.Any())
            {
                <div class="text-center py-10 opacity-60">
                    <p>Учасників не знайдено.</p>
                </div>
            }
        </div>

        
        @if (Model.Users.TotalPages > 1)
        {
            <div class="flex flex-col items-center mt-6 gap-3">
                <div class="join shadow-sm">
                    @if (Model.Users.CurrentPage > 1)
                    {
                        <a asp-action="ManageDepartment" asp-route-id="@dept?.Id" asp-route-usersPage="@(Model.Users.CurrentPage - 1)" asp-route-query="@ViewBag.Query"
                           class="join-item btn bg-base-100 hover:bg-base-200 border-base-200">«</a>
                    }
                    else
                    {
                        <button class="join-item btn btn-disabled bg-base-100 border-base-200">«</button>
                    }

                    @{
                        var uPageNumbers = new List<int>();
                        for (var i = 1; i <= Model.Users.TotalPages; i++)
                        {
                            if (i == 1 || i == Model.Users.TotalPages || (i >= Model.Users.CurrentPage - 1 && i <= Model.Users.CurrentPage + 1))
                                uPageNumbers.Add(i);
                        }
                        int? uLastPage = null;
                    }

                    @foreach (var p in uPageNumbers)
                    {
                        if (uLastPage != null && p - uLastPage > 1)
                        {
                            <button class="join-item btn btn-disabled bg-base-100 border-base-200 pointer-events-none">...</button>
                        }
                        if (p == Model.Users.CurrentPage)
                        {
                            <button class="join-item btn btn-active btn-neutral pointer-events-none">@p</button>
                        }
                        else
                        {
                            <a asp-action="ManageDepartment" asp-route-id="@dept?.Id" asp-route-usersPage="@p" asp-route-query="@ViewBag.Query"
                               class="join-item btn bg-base-100 hover:bg-base-200 border-base-200">@p</a>
                        }
                        uLastPage = p;
                    }

                    @if (Model.Users.CurrentPage < Model.Users.TotalPages)
                    {
                        <a asp-action="ManageDepartment" asp-route-id="@dept?.Id" asp-route-usersPage="@(Model.Users.CurrentPage + 1)" asp-route-query="@ViewBag.Query"
                           class="join-item btn bg-base-100 hover:bg-base-200 border-base-200">»</a>
                    }
                    else
                    {
                        <button class="join-item btn btn-disabled bg-base-100 border-base-200">»</button>
                    }
                </div>
                <div class="text-sm text-base-content/70 font-medium">Сторінка @Model.Users.CurrentPage з @Model.Users.TotalPages</div>
            </div>
        }
    </div>
</div>


<div class="divider my-4"></div>

<div class="mb-6 flex justify-between items-center flex-wrap gap-4">
    <div>
        <h2 class="text-3xl font-black mb-1 flex items-center gap-3">
            Заходи
            <span class="badge badge-lg badge-neutral">@Model.Events.TotalCount всього</span>
        </h2>
        <p class="text-base-content/70 text-sm">Всі заходи, включаючи чернетки. Лише автор або супер-адмін може видаляти.</p>
    </div>
    <a asp-controller="Events" asp-action="Create" class="btn btn-primary shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 mr-1"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
        Створити Захід
    </a>
</div>

<div class="overflow-x-auto bg-base-100 rounded-3xl shadow-xl border border-base-200 mb-6">
    <table class="table table-zebra w-full">
        <thead>
        <tr class="bg-base-200 text-sm">
            <th>Назва</th>
            <th>Дата початку</th>
            <th>Локація</th>
            <th>Статус</th>
            <th>Теги</th>
            <th>Дії</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var ev in Model.Events.Items)
        {
            var isCreator = ev.Id != Guid.Empty; // placeholder — creator info not in EventPreview
            var canDelete = isSuperAdmin; // full check done server-side on POST
            
            <tr class="hover">
                <td>
                    <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id" class="font-bold hover:text-primary transition-colors">
                        @ev.Title
                    </a>
                </td>
                <td class="text-sm text-base-content/70">@ev.StartTimeUtc.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</td>
                <td class="text-sm">@ev.Location</td>
                <td>
                    @if (ev.StartTimeUtc > DateTime.UtcNow)
                    {
                        <span class="badge badge-success badge-sm font-semibold">Майбутній</span>
                    }
                    else
                    {
                        <span class="badge badge-ghost badge-sm font-semibold">Завершений</span>
                    }
                </td>
                <td>
                    <div class="flex flex-wrap gap-1">
                        @foreach (var tag in ev.Tags.Take(2))
                        {
                            <span class="badge bg-base-200 badge-sm">@tag</span>
                        }
                        @if (ev.Tags.Count() > 2)
                        {
                            <span class="badge bg-base-200 badge-sm">+@(ev.Tags.Count() - 2)</span>
                        }
                    </div>
                </td>
                <td>
                    <div class="flex items-center gap-2">
                        <a asp-controller="Events" asp-action="Edit" asp-route-id="@ev.Id" class="btn btn-ghost btn-xs">Редагувати</a>
                        <form asp-controller="Events" asp-action="Delete" asp-route-id="@ev.Id" method="post"
                              onsubmit="return confirm('Видалити «@ev.Title»? Цю дію неможливо скасувати.');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-error btn-xs">Видалити</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
    @if (!Model.Events.Items.Any())
    {
        <div class="text-center py-10 opacity-60">
            <p>Заходів не знайдено.</p>
        </div>
    }
</div>


@if (Model.Events.TotalPages > 1)
{
    <div class="flex flex-col items-center mt-6 mb-8 gap-3">
        <div class="join shadow-sm">
            @if (Model.Events.CurrentPage > 1)
            {
                <a asp-action="ManageDepartment" asp-route-id="@dept?.Id" asp-route-eventsPage="@(Model.Events.CurrentPage - 1)" asp-route-query="@ViewBag.Query"
                   class="join-item btn bg-base-100 hover:bg-base-200 border-base-200">«</a>
            }
            else
            {
                <button class="join-item btn btn-disabled bg-base-100 border-base-200">«</button>
            }

            @{
                var ePageNumbers = new List<int>();
                for (var i = 1; i <= Model.Events.TotalPages; i++)
                {
                    if (i == 1 || i == Model.Events.TotalPages || (i >= Model.Events.CurrentPage - 1 && i <= Model.Events.CurrentPage + 1))
                        ePageNumbers.Add(i);
                }
                int? eLastPage = null;
            }

            @foreach (var p in ePageNumbers)
            {
                if (eLastPage != null && p - eLastPage > 1)
                {
                    <button class="join-item btn btn-disabled bg-base-100 border-base-200 pointer-events-none">...</button>
                }
                if (p == Model.Events.CurrentPage)
                {
                    <button class="join-item btn btn-active btn-neutral pointer-events-none">@p</button>
                }
                else
                {
                    <a asp-action="ManageDepartment" asp-route-id="@dept?.Id" asp-route-eventsPage="@p" asp-route-query="@ViewBag.Query"
                       class="join-item btn bg-base-100 hover:bg-base-200 border-base-200">@p</a>
                }
                eLastPage = p;
            }

            @if (Model.Events.CurrentPage < Model.Events.TotalPages)
            {
                <a asp-action="ManageDepartment" asp-route-id="@dept?.Id" asp-route-eventsPage="@(Model.Events.CurrentPage + 1)" asp-route-query="@ViewBag.Query"
                   class="join-item btn bg-base-100 hover:bg-base-200 border-base-200">»</a>
            }
            else
            {
                <button class="join-item btn btn-disabled bg-base-100 border-base-200">»</button>
            }
        </div>
        <div class="text-sm text-base-content/70 font-medium">Сторінка @Model.Events.CurrentPage з @Model.Events.TotalPages</div>
    </div>
}
