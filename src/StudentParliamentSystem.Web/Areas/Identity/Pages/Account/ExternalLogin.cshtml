@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Реєстрація";
}

<div class="flex justify-center items-start py-8">
    <div class="card bg-base-100 shadow-xl border border-base-200 w-full max-w-md">
        <div class="card-body gap-6">
            <div class="text-center">
                <h1 class="text-3xl font-bold">@ViewData["Title"]</h1>
                <h2 id="external-login-title" class="text-lg font-medium text-base-content/70 mt-1">Пов'яжіть акаунт @Model.ProviderDisplayName</h2>
            </div>

            <div id="external-login-description" class="alert alert-info text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span>Ви успішно автентифікувались через <strong>@Model.ProviderDisplayName</strong>. Будь ласка, введіть email і натисніть «Зареєструватись».</span>
            </div>

            <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="flex flex-col gap-4">
                <div asp-validation-summary="ModelOnly" class="alert alert-error text-sm" role="alert"></div>

                <div class="form-control">
                    <label asp-for="Input.Email" class="label"><span class="label-text font-medium">Email</span></label>
                    <input asp-for="Input.Email" class="input input-bordered w-full" autocomplete="email" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="label-text-alt text-error mt-1"></span>
                </div>

                <button type="submit" class="btn btn-primary w-full">Зареєструватись</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
