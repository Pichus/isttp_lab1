@model StudentParliamentSystem.Api.ViewModels.PaginationViewModel

@{
    ViewData["Title"] = "Управління Користувачами";
}

<div class="mb-8 flex justify-between items-end flex-wrap gap-4">
    <div>
        <h1 class="text-4xl font-black mb-2 flex items-center gap-3">
            Користувачі
            <span class="badge badge-lg badge-neutral">3 всього</span>
        </h1>
        <p class="text-base-content/70">Управління доступом, ролями та користувачами системи.</p>
    </div>
    <div>
        <button class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
            Додати Користувача
        </button>
    </div>
</div>

<div class="bg-base-100 shadow-xl rounded-3xl border border-base-200 p-6 mb-8 flex flex-col sm:flex-row gap-4">
    <div class="form-control w-full">
        <label class="label"><span class="label-text font-bold">Пошук користувача</span></label>
        <div class="input-group flex w-full">
            <input type="text" placeholder="Ім'я, email, або ID" class="input input-bordered w-full rounded-r-none" />
            <button class="btn btn-square btn-neutral rounded-l-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            </button>
        </div>
    </div>
    <div class="form-control w-full sm:w-xs">
        <label class="label"><span class="label-text font-bold">Фільтр ролей</span></label>
        <select class="select select-bordered w-full">
            <option disabled selected>Усі ролі</option>
            <option>Студент</option>
            <option>Член СПФ</option>
            <option>Голова Департаменту</option>
            <option>Адмін Читалки</option>
            <option>Адмін (Тех)</option>
        </select>
    </div>
</div>

<div class="overflow-x-auto bg-base-100 rounded-3xl shadow-xl border border-base-200">
  <table class="table table-zebra w-full">
    <!-- head -->
    <thead>
      <tr class="bg-base-200 text-sm">
        <th>Користувач</th>
        <th>Електронна пошта</th>
        <th>Ролі / Статуси</th>
        <th>Департамент</th>
        <th>Дії</th>
      </tr>
    </thead>
    <tbody>
      <!-- User 1 -->
      <tr class="hover">
        <td>
          <div class="flex items-center space-x-3">
            <div class="avatar placeholder">
              <div class="bg-neutral text-neutral-content rounded-full w-10">
                <span class="text-sm">МК</span>
              </div>
            </div>
            <div>
              <div class="font-bold">Микола Коваленко</div>
            </div>
          </div>
        </td>
        <td class="text-sm">m.kovalenko@student.kpi.ua</td>
        <td>
          <div class="flex flex-wrap gap-1">
            <span class="badge badge-success badge-sm font-bold">Студент</span>
          </div>
        </td>
        <td class="text-base-content/50">—</td>
        <th>
          <a asp-action="Edit" asp-route-id="1" class="btn btn-ghost btn-sm">Редагувати</a>
        </th>
      </tr>

      <!-- User 2 -->
      <tr class="hover">
        <td>
          <div class="flex items-center space-x-3">
            <div class="avatar placeholder">
              <div class="bg-primary text-primary-content rounded-full w-10">
                <span class="text-sm">ДШ</span>
              </div>
            </div>
            <div>
              <div class="font-bold">Дар'я Шевченко</div>
            </div>
          </div>
        </td>
        <td class="text-sm">d.shevchenko@student.kpi.ua</td>
        <td>
          <div class="flex flex-wrap gap-1">
            <span class="badge badge-success badge-sm font-bold">Студент</span>
            <span class="badge badge-primary badge-sm font-bold">Член СПФ</span>
            <span class="badge badge-warning badge-sm font-bold">Голова Департаменту</span>
          </div>
        </td>
        <td class="font-semibold text-sm">КультДеп</td>
        <th>
          <a asp-action="Edit" asp-route-id="2" class="btn btn-ghost btn-sm">Редагувати</a>
        </th>
      </tr>

       <!-- User 3 -->
      <tr class="hover">
        <td>
          <div class="flex items-center space-x-3">
             <div class="avatar placeholder">
              <div class="bg-secondary text-secondary-content rounded-full w-10">
                <span class="text-sm">ОП</span>
              </div>
            </div>
            <div>
              <div class="font-bold">Олег Прокопенко</div>
            </div>
          </div>
        </td>
        <td class="text-sm">o.prokopenko@student.kpi.ua</td>
        <td>
          <div class="flex flex-wrap gap-1">
            <span class="badge badge-success badge-sm font-bold">Студент</span>
            <span class="badge badge-secondary badge-sm font-bold">Адмін Читалки</span>
          </div>
        </td>
        <td class="font-semibold text-sm">Коворкінг</td>
        <th>
          <a asp-action="Edit" asp-route-id="3" class="btn btn-ghost btn-sm">Редагувати</a>
        </th>
      </tr>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<div class="flex flex-col items-center mt-8 mb-4 gap-4">
    <div class="join shadow-sm">
        @if (Model.CurrentPage > 1)
        {
            <a asp-action="Users" asp-route-page="@(Model.CurrentPage - 1)" class="join-item btn bg-base-100 hover:bg-base-200 border-base-200">«</a>
        }
        else
        {
            <button class="join-item btn btn-disabled bg-base-100 border-base-200">«</button>
        }

        @{
            var pageNumbers = new List<int>();
            for (int i = 1; i <= Model.TotalPages; i++)
            {
                if (i == 1 || i == Model.TotalPages || (i >= Model.CurrentPage - 1 && i <= Model.CurrentPage + 1))
                {
                    pageNumbers.Add(i);
                }
            }
            
            int? lastPageNumber = null;
        }

        @foreach (var p in pageNumbers)
        {
            if (lastPageNumber != null && p - lastPageNumber > 1)
            {
                <button class="join-item btn btn-disabled bg-base-100 border-base-200 pointer-events-none">...</button>
            }
            
            if (p == Model.CurrentPage)
            {
                <button class="join-item btn btn-active btn-neutral pointer-events-none">@p</button>
            }
            else
            {
                <a asp-action="Users" asp-route-page="@p" class="join-item btn bg-base-100 hover:bg-base-200 border-base-200">@p</a>
            }
            
            lastPageNumber = p;
        }

        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a asp-action="Users" asp-route-page="@(Model.CurrentPage + 1)" class="join-item btn bg-base-100 hover:bg-base-200 border-base-200">»</a>
        }
        else
        {
            <button class="join-item btn btn-disabled bg-base-100 border-base-200">»</button>
        }
    </div>
    <div class="text-sm text-base-content/70 font-medium">
        Сторінка @Model.CurrentPage з @Model.TotalPages
    </div>
</div>