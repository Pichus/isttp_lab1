@{
    ViewData["Title"] = "Майбутні Заходи";
}

<div class="mb-8 flex justify-between items-end flex-wrap gap-4">
    <div>
        <h1 class="text-4xl font-black mb-2">Заходи СПФ</h1>
        <p class="text-base-content/70">Реєструйся, долучайся до організації або просто відпочивай на наших івентах.</p>
    </div>
    <div class="flex gap-2">
        <a href="/Events/Archive" class="btn btn-outline btn-sm lg:btn-md">Архів Заходів</a>
        <a href="/Events/Create" class="btn btn-primary btn-sm lg:btn-md flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
            Створити Івент
        </a>
    </div>
</div>

<!-- Search and Filter -->
<div class="bg-base-100 p-4 rounded-xl shadow-sm border border-base-200 mb-8 flex flex-col sm:flex-row gap-4">
    <div class="form-control w-full">
        <div class="input-group flex w-full">
            <input type="text" placeholder="Пошук заходів..." class="input input-bordered w-full rounded-r-none" />
            <button class="btn btn-square btn-primary rounded-l-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            </button>
        </div>
    </div>
    <select class="select select-bordered w-full sm:w-xs">
        <option disabled selected>Фільтр за тегом</option>
        <option>Вечірка</option>
        <option>Лекція</option>
        <option>Спорт</option>
        <option>Кіноперегляд</option>
    </select>
</div>

<!-- Events Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <!-- Dummy Event Card -->
    <div class="card bg-base-100 shadow-xl overflow-hidden border border-base-200 group hover:shadow-2xl transition-all duration-300">
        <figure class="relative h-48 bg-base-300">
            <!-- Mock Poster -->
            <div class="absolute inset-0 bg-gradient-to-tr from-primary/30 to-secondary/30 flex items-center justify-center">
                 <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-base-content/30"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" /></svg>
            </div>
            <div class="absolute top-2 right-2 flex gap-1">
                <span class="badge badge-accent shadow-sm font-semibold text-xs py-2">Завтра</span>
            </div>
        </figure>
        <div class="card-body">
            <h2 class="card-title text-xl font-bold group-hover:text-primary transition-colors">
                Посвята Першокурсників
            </h2>
            <div class="flex items-center gap-1 text-sm text-base-content/60 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                12 жовтня, 18:00
            </div>
             <div class="flex items-center gap-1 text-sm text-base-content/60 mb-4">
               <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
                Малий актовий зал
            </div>
            <p class="text-sm line-clamp-2">Грандіозна подія для всіх студентів першого курсу. Не пропусти!</p>
            <div class="card-actions justify-between items-center mt-4">
                <div class="flex gap-1 flex-wrap">
                    <div class="badge badge-outline text-xs">Вечірка</div>
                </div>
                <a href="/Events/Details/1" class="btn btn-primary btn-sm rounded-full px-6">Детальніше</a>
            </div>
        </div>
    </div>

    <!-- Dummy Event Card 2 -->
    <div class="card bg-base-100 shadow-xl overflow-hidden border border-base-200 group hover:shadow-2xl transition-all duration-300">
        <figure class="relative h-48 bg-base-300">
            <!-- Mock Poster -->
            <div class="absolute inset-0 bg-gradient-to-tr from-secondary/30 to-accent/30 flex items-center justify-center">
                 <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-base-content/30"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" /></svg>
            </div>
            <div class="absolute top-2 right-2 flex gap-1">
                <span class="badge badge-secondary shadow-sm font-semibold text-xs py-2">За тиждень</span>
            </div>
        </figure>
        <div class="card-body">
            <h2 class="card-title text-xl font-bold group-hover:text-primary transition-colors">
                Кіноніч: Марвел
            </h2>
            <div class="flex items-center gap-1 text-sm text-base-content/60 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                19 жовтня, 21:00
            </div>
             <div class="flex items-center gap-1 text-sm text-base-content/60 mb-4">
               <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
                Коворкінг простору
            </div>
            <p class="text-sm line-clamp-2">Перегляд класики марвел з попкорном. Кількість місць обмежена!</p>
            <div class="card-actions justify-between items-center mt-4">
                <div class="flex gap-1 flex-wrap">
                    <div class="badge badge-outline text-xs">Кіноперегляд</div>
                    <div class="badge badge-outline text-xs">Відпочинок</div>
                </div>
                <a href="/Events/Details/2" class="btn btn-primary btn-sm rounded-full px-6">Детальніше</a>
            </div>
        </div>
    </div>
</div>
