@using System.Security.Claims
@using StudentParliamentSystem.Core.Aggregates.Role
@model StudentParliamentSystem.Core.Aggregates.Event.Event

@{
    ViewData["Title"] = Model.Title;
    var tags = Model.Tags.Select(t => t.Name).ToList();
    var isUpcoming = Model.StartTimeUtc > DateTime.UtcNow;

    var userIdStr = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isCreator = Guid.TryParse(userIdStr, out var userId) && Model.CreatedByUserId == userId;
    var isSuperAdmin = User.IsInRole(nameof(RoleName.SuperAdmin));
    var canEdit = isCreator || isSuperAdmin;
}

<div class="mb-8 flex justify-between items-center flex-wrap gap-4">
    <a asp-action="Index" class="btn btn-ghost gap-2 pl-0 hover:bg-transparent">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
        Назад до подій
    </a>

    @if(canEdit)
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline btn-neutral">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 mr-2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" /></svg>
            Редагувати подію
        </a>
    }
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-8">
        
        <div class="bg-base-100 rounded-3xl shadow-xl border border-base-200 p-8 md:p-12 overflow-hidden relative">
            <div class="absolute top-0 left-0 w-full h-3 bg-gradient-to-r from-primary to-secondary"></div>
            
            <div class="flex flex-wrap items-center gap-4 mb-6">
                <div class="badge badge-neutral badge-lg shadow-sm font-semibold">@Model.Department?.Name</div>
                @if(isUpcoming)
                {
                    <div class="badge badge-success badge-outline badge-lg shadow-sm font-semibold">Анонсовано</div>
                }
                else
                {
                    <div class="badge badge-ghost badge-lg shadow-sm font-semibold">Завершено</div>
                }
            </div>

            <h1 class="text-4xl md:text-5xl font-black mb-6 leading-tight">@Model.Title</h1>
            
            <div class="prose prose-lg max-w-none text-base-content/80 mt-8">
                @Html.Raw(Model.Description.Replace("\n", "<br/>"))
            </div>

            @if(tags.Any())
            {
                <div class="divider my-8"></div>
                <div class="flex flex-wrap gap-2">
                    @foreach (var tag in tags)
                    {
                        <span class="badge bg-base-200 text-sm font-semibold py-4 px-4 hover:bg-base-300 transition-colors">@tag</span>
                    }
                </div>
            }
        </div>
        
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
        
        <div class="bg-base-100 rounded-3xl shadow-xl border border-base-200 p-8">
            <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-primary"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" /></svg>
                Деталі заходу
            </h3>
            
            <ul class="space-y-6">
                <li class="flex items-start gap-4">
                    <div class="bg-primary/10 text-primary p-3 rounded-2xl shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    </div>
                    <div>
                        <p class="text-sm text-base-content/60 font-semibold mb-1">Початок</p>
                        <p class="font-bold">@Model.StartTimeUtc.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</p>
                    </div>
                </li>
                
                <li class="flex items-start gap-4">
                    <div class="bg-primary/10 text-primary p-3 rounded-2xl shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z" /></svg>
                    </div>
                    <div>
                        <p class="text-sm text-base-content/60 font-semibold mb-1">Завершення</p>
                        <p class="font-bold">@Model.EndTimeUtc.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</p>
                    </div>
                </li>

                <li class="flex items-start gap-4">
                    <div class="bg-secondary/10 text-secondary p-3 rounded-2xl shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
                    </div>
                    <div>
                        <p class="text-sm text-base-content/60 font-semibold mb-1">Локація</p>
                        <p class="font-bold">@Model.Location</p>
                    </div>
                </li>

                @if(Model.MaxParticipants.HasValue)
                {
                    <li class="flex items-start gap-4">
                        <div class="bg-accent/10 text-accent p-3 rounded-2xl shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
                        </div>
                        <div>
                            <p class="text-sm text-base-content/60 font-semibold mb-1">Ліміт учасників</p>
                            <p class="font-bold">@Model.MaxParticipants осіб</p>
                        </div>
                    </li>
                }
            </ul>

            @if(isUpcoming)
            {
                <div class="divider my-6"></div>
                <button class="btn btn-primary btn-lg w-full shadow-xl shadow-primary/30" disabled>Реєстрація незабаром</button>
            }
        </div>

    </div>
</div>
